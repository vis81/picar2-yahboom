#include <zephyr/dt-bindings/sensor/qdec_stm32.h>

/ {
    servo0: nrf-servo0 {
        compatible = "pwm-servo";
        pwms = <&pwm_sw_t3 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
        init_value = <50>;
        min_pulse_us = <600>;
        max_pulse_us = <2500>;
        status = "okay";
    };

	motor_r: motor_r {
        compatible = "hbridge";
        pwms = <&pwm_t8_m1_m2 1 PWM_MSEC(1) PWM_POLARITY_NORMAL>,
				<&pwm_t8_m1_m2 2 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
        status = "okay";
    };

	motor_l: motor_l {
        compatible = "hbridge";
        pwms = <&pwm_t8_m1_m2 4 PWM_MSEC(1) PWM_POLARITY_NORMAL>,
				<&pwm_t8_m1_m2 3 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
        status = "okay";
    };

};

&timers2 {
	st,prescaler = <1000>;
	status = "okay";

	qdec1: qdec_t2_m1 {
		status = "okay";
		st,counts-per-revolution = <418>;
		st,input-filter-level = <NO_FILTER>;
	};
};

&timers3 {
	st,prescaler = <1000>;
	status = "okay";

	pwm_sw_t3: sw_pwm {
		compatible = "st,stm32-pwm-sw";
		status = "okay";
		label = "servo_pwm";
		gpios = <&gpioc 3 GPIO_ACTIVE_HIGH>,
				<&gpioc 2 GPIO_ACTIVE_HIGH>,
				<&gpioc 1 GPIO_ACTIVE_HIGH>,
				<&gpioc 0 GPIO_ACTIVE_HIGH>;
		channels = <1 2 3 4>;
		#pwm-cells = <3>;
	};
};

&timers8 {
	st,prescaler = <1000>;
	status = "disabled";

	pwm_t8_m1_m2: pwm {
		label = "pwm_t8_m1_m2";
		status = "okay";
	};

};

&usart2 {
	current-speed = <100000>;
	parity = "even";
	stop-bits = "2";
	data-bits = <8>;
	status = "okay";
    rc: sbus {
        compatible = "futaba,sbusreceiver";
        label = "RECEIVER0";
        status = "okay";
    };
};
